# Copy this file to .env and insert the real SQL Server credentials.
# The backend replaces {dbName} with the database selected in the UI.
DB_CONNECTION_STRING=Server=your-server;Database={dbName};User Id=sa;Password=987654321@ANhung!@$;Encrypt=true;TrustServerCertificate=false
DB_PORT=3001
DB_DEFAULT_DATABASE=isoft.asianasa.com
# Temporary snapshot size. Increase this only when the selected context can hold it.
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_VECTOR_SIZE=384
RAG_CHAT_MODEL=gemma3:1b
RAG_TOP_K=5
GOODS_ACCOUNT=1561
GOODS_PRICE_LIST=BGC
# Optional when ollama.exe is not available through PATH.
# OLLAMA_BIN=C:\\Users\\your-user\\AppData\\Local\\Programs\\Ollama\\ollama.exe


